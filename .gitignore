# -------------------------------------------------------
# Power Platform / App1 - .gitignore
# -------------------------------------------------------

# CREDENTIALS - never commit this folder
Security/

# Build output (packed solution zips - generated by scripts/workflows)
out/

# pac CLI auth profiles (contain credentials - never commit)
.pac/

# Local developer overrides
*.local.ps1

# OS files
.DS_Store
Thumbs.db
desktop.ini

# VS Code workspace-specific settings (keep extensions.json / settings.json if you want)
.vscode/*.code-workspace

# Temp / log files
*.tmp
*.log
*.bak

# Node (if any tooling is added later)
node_modules/
